<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trump Truth Social Feed — {{ date }}</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; background: #FFFFFF; margin: 0; padding: 0; color: #0F172A; }
    .wrapper { max-width: 620px; margin: 0 auto; background: #FFFFFF; }
    .header { border-bottom: 2px solid #E2E8F0; padding: 28px 32px 20px; text-align: center; }
    .header h1 { margin: 0; font-size: 22px; letter-spacing: -0.3px; color: #0F172A; font-weight: 700; }
    .header p { margin: 6px 0 0; font-size: 13px; color: #475569; letter-spacing: 0.3px; text-transform: uppercase; }
    .body { padding: 24px 32px; }
    .greeting { font-size: 16px; margin-bottom: 16px; color: #0F172A; }
    .summary-box { background: #F8FAFC; border-left: 3px solid #2563EB; padding: 16px 20px; margin-bottom: 24px; border-radius: 2px; }
    .summary-box .count { font-size: 12px; color: #475569; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.4px; }
    .summary-box p { margin: 0; font-size: 15px; line-height: 1.5; color: #0F172A; }
    .post { border-bottom: 1px solid #E2E8F0; padding: 16px 0; }
    .post:last-child { border-bottom: none; }
    .post-header { display: table; width: 100%; margin-bottom: 8px; }
    .post-meta { display: table-cell; font-size: 12px; color: #475569; }
    .post-link { display: table-cell; text-align: right; font-size: 12px; white-space: nowrap; }
    .post-link a { color: #2563EB; text-decoration: none; border-bottom: 1px solid #BFDBFE; }
    .post-content { font-size: 15px; line-height: 1.6; margin: 0 0 10px; color: #0F172A; }
    .categories { margin-top: 10px; }
    .pill { display: inline-block; background: #F1F5F9; color: #334155; font-size: 11px; padding: 2px 8px; border-radius: 10px; margin-right: 4px; margin-bottom: 4px; border: 1px solid #E2E8F0; }
    .footer { border-top: 1px solid #E2E8F0; padding: 20px 32px; font-size: 12px; color: #475569; text-align: center; line-height: 1.6; }
    .footer a { color: #2563EB; }
    .media-image { display:block; max-width:100%; border-radius:4px; margin:8px 0; }
    .media-video { margin:8px 0; }
    .media-video a { display:inline-flex; align-items:center; gap:6px; background:#F8FAFC; border:1px solid #E2E8F0; color:#1D4ED8; font-size:13px; padding:7px 14px; border-radius:4px; text-decoration:none; font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif; }
    .media-video a:hover { background:#EFF6FF; }
    .media-video .play-icon { font-size:11px; color:#2563EB; }
  </style>
</head>
<body>
  <div class="wrapper">
    <!-- Header -->
    <div class="header">
      <h1>Trump Truth Social Feed</h1>
      <p>Daily Digest &mdash; {{ date }}</p>
    </div>

    <div class="body">
      <!-- Greeting -->
      <p class="greeting">Hi there,</p>

      <!-- Daily Summary -->
      <div class="summary-box">
        <div class="count">{{ data.summary.new_posts_count }} post{{ "s" if data.summary.new_posts_count != 1 else "" }} today</div>
        <p>{{ data.summary.daily_summary }}</p>
      </div>

      <!-- Posts -->
      {% for post in data.new_posts %}
      <div class="post">
        <div class="post-header">
          <span class="post-meta">{{ post.created_at_et }}</span>
          <span class="post-link"><a href="{{ post.url }}">View on Truth Social &rarr;</a></span>
        </div>
        <p class="post-content">{{ post.content }}</p>
        {% if post.media_items %}
        <div class="media-block">
          {% for item in post.media_items %}
            {% if item.type == "image" %}
              <img class="media-image" src="{{ item.url }}" alt="[Image — enable image loading to view]">
            {% else %}
              <div class="media-video"><a href="{{ item.url }}"><span class="play-icon">&#9654;</span>&nbsp; Video from Truth Social</a></div>
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
        {% if post.categories %}
        <div class="categories">
          {% for cat in post.categories %}<span class="pill">{{ cat }}</span>{% endfor %}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>
        You are receiving this because you subscribed to the Trump Truth Social Feed.<br>
        <a href="{{ unsubscribe_url }}">Unsubscribe</a>
      </p>
    </div>
  </div>
</body>
</html>

# ── LLM Enrichment ────────────────────────────────────────────────────
# Provider selection: auto | api | claude_code_cli | codex_cli
# "auto" tries each backend in order until one works.
LLM_PROVIDER=auto

# JSON array of models for LiteLLM to try in order (first success wins).
# Leave as [] to fall back to a CLI provider (claude_code_cli / codex_cli).
LLM_MODELS=["gemini/gemini-3-flash-preview","gemini/gemini-2.5-flash"]

# ── API Keys ──────────────────────────────────────────────────────────
# Required only when LLM_PROVIDER=api (or auto falls through to API)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Email Notifications (optional — leave blank to disable) ───────────
SENDER_GMAIL=          # must be a Gmail address (used for SMTP auth)
GMAIL_APP_PASSWORD=    # 16-char App Password from Google Account settings
RECEIVER_EMAIL=        # recipient address (any email provider)

# ── API Keys ──────────────────────────────────────────────────────────
# Required only when LLM_PROVIDER=api (or auto falls through to API)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Email Notifications (optional — leave blank to disable) ───────────
SENDER_GMAIL=          # must be a Gmail address (used for SMTP auth)
GMAIL_APP_PASSWORD=    # 16-char App Password from Google Account settings
RECEIVER_EMAIL=        # recipient address (any email provider)

# ── Behavior Settings (optional — all have defaults) ──────────────────
# Use SECTION__KEY=value notation (double underscore = nested delimiter)

# Pipeline
# PIPELINE__HOURS=24
# PIPELINE__LOG_LEVEL=INFO
# PIPELINE__SAVE_RAW=false
# PIPELINE__SAVE_ENRICHED=false
# PIPELINE__SAVE_LOGS=false
# PIPELINE__ENABLE_LLM=true     # set to false to skip LLM enrichment entirely
# PIPELINE__ENABLE_NOTIFY=true  # set to false to skip email notification entirely

# LLM
# LLM__PROVIDER=auto                           # auto | api | claude_code_cli | codex_cli
# LLM__MODELS=["gemini/gemini-3-flash-preview", "gemini/gemini-2.5-flash"]
# LLM__API_KWARGS={"num_retries": 3}

# Fetch
# FETCH__ARCHIVE_URL=https://ix.cnn.io/data/truth-social/truth_archive.json
# FETCH__TIMEOUT=120
# FETCH__USER_AGENT=ttsfeed/0.1 (Truth Social archive tracker)

# Notify (email notifications)
# NOTIFY__TIMEZONE=America/New_York
# NOTIFY__SMTP_HOST=smtp.gmail.com
# NOTIFY__SMTP_PORT=465
# NOTIFY__SUBJECT_TEMPLATE=Trump Truth Social Feed — {date} ({count} new posts)

# Output paths
# PATHS__RAW_OUTPUT_DIR=data/raw
# PATHS__ENRICHED_OUTPUT_DIR=data/enriched
# PATHS__LOGS_OUTPUT_DIR=data/logs

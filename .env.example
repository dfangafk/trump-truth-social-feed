# ── LLM Enrichment ────────────────────────────────────────────────────
# Provider selection: auto | api | claude_code_cli | codex_cli
# "claude_code_cli" uses Claude Code CLI (`claude -p`), and "codex_cli" uses Codex CLI (`codex exec`).
# "auto" tries each backend in order until one works.
LLM_PROVIDER=auto

# Model string passed to LiteLLM (e.g. openai/gpt-4o, claude-3-5-sonnet-20241022)
# Leave blank to use the provider's default model.
LLM_MODEL=

# ── API Keys ──────────────────────────────────────────────────────────
# Required only when LLM_PROVIDER=api (or auto falls through to API)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
